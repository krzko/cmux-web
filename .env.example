# cmux socket (the app shells out to the cmux CLI, which reads these).
CMUX_SOCKET_PATH=/Users/you/.local/state/cmux/cmux-501.sock
CMUX_SOCKET_PASSWORD=
# Optional: absolute path to the cmux binary (default /opt/homebrew/bin/cmux).
CMUX_BIN=/opt/homebrew/bin/cmux
# Optional: per-call RPC timeout in ms (default 8000).
CMUX_RPC_TIMEOUT_MS=8000
# Optional: events resume cursor file (default in the OS temp dir).
CMUX_EVENTS_CURSOR=

# App auth gate. Leave APP_PASSWORD empty for local dev (gate disabled); set it
# before exposing the app on the tailnet.
APP_PASSWORD=
# Optional: HMAC secret for session cookies (defaults to APP_PASSWORD).
APP_SESSION_SECRET=
# Optional: session lifetime in days (default 30).
APP_SESSION_TTL_DAYS=30

# Optional: port for `pnpm serve:tailnet` (default 31337).
PORT=31337
